<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Верхняя панель с информацией о классе -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A237E"
        android:padding="20dp">

        <TextView
            android:id="@+id/textViewDetailClassName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Название класса"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Код: "
                android:textSize="14sp"
                android:textColor="#B0BEC5" />

            <TextView
                android:id="@+id/textViewDetailCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABC123"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textViewDetailRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Создатель"
            android:textSize="12sp"
            android:textColor="#4CAF50"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Кнопки действий -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <Button
            android:id="@+id/buttonCreateTest"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#1A237E"
            android:text="+ Тест"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/buttonAddMaterial"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="#E8EAF6"
            android:text="+ Материал"
            android:textColor="#1A237E"
            android:textSize="12sp" />

        <Button
            android:id="@+id/buttonViewResults"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="#FF9800"
            android:text="📊 Результаты"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Вкладки -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:tabIndicatorColor="#1A237E"
        app:tabSelectedTextColor="#1A237E"
        app:tabTextColor="#757575" />

    <!-- Контейнер для фрагментов -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>