<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Личный кабинет"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Преподаватель"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginBottom="32dp" />

    <!-- Карточка с информацией -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email:"
            android:textSize="14sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/textViewEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textSize="18sp"
            android:textColor="#000000"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Роль:"
            android:textSize="14sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/textViewRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="teacher"
            android:textSize="18sp"
            android:textColor="#000000" />

    </LinearLayout>

    <!-- Заглушки для будущих кнопок -->
    <Button
        android:id="@+id/buttonCreateClass"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Создать класс"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A237E"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/buttonJoinClass"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Присоединиться к классу"
        android:textSize="16sp"
        android:textColor="#1A237E"
        android:backgroundTint="#FFFFFF"
        android:strokeColor="#1A237E"
        android:strokeWidth="2"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/buttonMyClasses"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Мои классы"
        android:textSize="16sp"
        android:textColor="#1A237E"
        android:backgroundTint="#FFFFFF"
        android:strokeColor="#1A237E"
        android:strokeWidth="2"
        android:layout_marginBottom="24dp" />


    <Button
        android:id="@+id/buttonLogout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Выйти"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336"
        />

</LinearLayout>