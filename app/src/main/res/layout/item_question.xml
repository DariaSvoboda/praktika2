<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textViewQuestionNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1."
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/textViewQuestionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Текст вопроса"
            android:textSize="16sp"
            android:textColor="#000000" />

    </LinearLayout>

    <TextView
        android:id="@+id/textViewQuestionType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Один ответ"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/textViewOptionsCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Вариантов: 4"
        android:textSize="12sp"
        android:textColor="#757575" />

</LinearLayout>