<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Присоединение к классу"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Введите код, полученный от создателя класса"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/editTextClassCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Код класса (например: ABC123)"
        android:inputType="textCapCharacters"
        android:maxLength="6"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/buttonJoin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Присоединиться"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A237E"
        android:layout_marginBottom="16dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Карточка с информацией о найденном классе -->
    <LinearLayout
        android:id="@+id/layoutClassInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:visibility="gone"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Найден класс:"
            android:textSize="14sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/textViewFoundClassName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textViewFoundCreator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/buttonConfirmJoin"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Подтвердить присоединение"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="12dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/textViewError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#F44336"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>