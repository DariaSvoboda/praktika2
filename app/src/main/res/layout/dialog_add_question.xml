<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Добавить вопрос"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/editTextQuestionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Текст вопроса"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Тип вопроса:"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioGroupType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/radioSingle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Один ответ"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioMultiple"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Несколько" />

        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Варианты ответов (отметьте правильные):"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <Button
            android:id="@+id/buttonAddOption"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Добавить вариант"
            android:textSize="12sp"
            android:textColor="#1A237E"
            android:backgroundTint="#E8EAF6"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/buttonSaveQuestion"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Сохранить вопрос"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A237E" />

    </LinearLayout>
</ScrollView>